# Базовый URL backend API (без завершающего слэша).
# Пусто — приложение работает только на моках (локальная разработка).
# Локально с backend: http://localhost:8080
# Продакшен: см. deploy/DEPLOY.md (Docker Compose)
VITE_API_BASE_URL=

# URL SSO (Keycloak / OpenID Connect). Пусто — mock-страница /login/sso.
# Пример для продакшена:
# VITE_SSO_URL=https://sso.ruc.local/realms/ruk/protocol/openid-connect/auth?client_id=lk-ruk&redirect_uri=...&response_type=code&scope=openid%20profile%20email
VITE_SSO_URL=
